#test Illegal instructions

  0x80000000 :
    lui    t0, 0xfff80000  ->  0x800002b7   // li t0, 0x80000080 
    addi   t0, t0, 0x80    ->  0x08028293
    csrrw  x0, 0x305, t0   ->  0x30529073   // mtvec = 0x80000040 
    addi   t1, x0, 0x88    ->  0x08800313   
    csrrw  x0, 0x300, t1   ->  0x30031073   // set MIE and MPIE
    csrrs  x0, 0x300, x0   ->  0x30002073   // read mstatus
    nop                    ->  0x00000013
    Illegal instr          ->  0xFFFFFFFF   // Illegal opcode
    nop                    ->  0x00000013
    csrrs  x0, 0x400, x0   ->  0x40002073   // CSR access fault
    nop                    ->  0x00000013
    ecall                  ->  0x00000073   // ecall
    nop                    ->  0x00000013
    ebreak                 ->  0x00100073   // ebreak
    nop                    ->  0x00000013
    jalr x0, 0x333(x0)     ->  0x33300067   // instruction misaligned address
    nop                    ->  0x00000013   // instruction access fault tested artificially
    nop                    ->  0x00000013 
    lw     t0, 2(t1)       ->  0x00232283   // load address misaligned
    lh     t0, 5(t1)       ->  0x00531283    
    lhu    t0, 1(t1)       ->  0x00135283  
    nop                    ->  0x00000013
    sw     t0, 2(t1)       ->  0x00532123   // store address misaligned
    sh     t0, 5(t1)       ->  0x005312a3
    nop                    ->  0x00000013
    sh     t0, 5(t1)       ->  0x005312a3   // 2 conflecting exceptions
    Illegal instr          ->  0xFFFFFFFF 
    nop                    ->  0x00000013

  0x80000080 :
    csrrs  x0, 0x300, x0   ->  0x30002073   // read mstatus
    csrrs  x0, 0x342, x0   ->  0x34202073   // read mcause
    csrrs  x0, 0x343, x0   ->  0x34302073   // read mtval    
    csrrs  t2, 0x341, x0   ->  0x341023f3   // read mepc
    addi   t2, t2, 4       ->  0x00438393   // mepc + 4
    csrrw  x0, 0x341, t2   ->  0x34139073   // write mepc
    mret                   ->  0x30200073

#test instructions count

    nop                    ->  0x00000013
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    csrrs  x0, 0xB02, x0   ->  0xB0202073   // read the instructions count
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    lw     t0, 4(x0)       ->  0x00402283   // triggering stalling mechanism
    addi   t0 , t0, 5      ->  0x00528293
    csrrs  x0, 0xB00, x0   ->  0xB0002073   // read the cycles count
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    lw     t0, 2(t1)       ->  0x00232283   // triggering flush mechanism
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    nop                    ->  0x00000013

