# test mret instruction

    addi   t0 , x0, 0x80   ->  0x08000293
    addi   t1 , x0, 0x8    ->  0x00c00313
    csrrw  x0, 0x300, t0   ->  0x30029073
    csrrs  t2, 0x300, x0   ->  0x300023f3
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    nop                    ->  0x00000013
    csrrw  x0, 0x341, t1   ->  0x34131073
