    lui    t0, 0x00012345  ->  0x123452b7
    addi   t0, t0, 0x678   ->  0x67828293
    addi   t1, t1, 0x55    ->  0x05530313
    addi   t2, t2, 0xCC    ->  0x0cc38393

    csrrw  s1, 0x340, t0   ->  0x340294f3
    csrrs  s1, 0x340, x0   ->  0x340024f3

    csrrwi s2, 0x341, 0x15 ->  0x341ad973
    csrrs  s2, 0x341, x0   ->  0x34102973

    csrrs  s3, 0x340, t1   ->  0x340329f3
    csrrs  s3, 0x340, x0   ->  0x340029f3

    csrrsi s4, 0x342, 0x15 ->  0x342aea73
    csrrs  s4, 0x342, x0   ->  0x34202a73

    csrrw  s5, 0x340, t0   ->  0x34029af3
    csrrc  s5, 0x340, t2   ->  0x3403baf3
    csrrs  s5, 0x340, x0   ->  0x34002af3

    csrrw  s6, 0x340, t0   ->  0x34029b73
    csrrci s6, 0x340, 0x15 ->  0x340afb73
    csrrs  s6, 0x340, x0   ->  0x34002b73

